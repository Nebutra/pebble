{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pebble",
  "version": "0.1.0",
  "identifier": "nebutra.pebble",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pebble",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "../../../resources/build/icon.png",
      "../../../resources/build/icon.icns",
      "../../../resources/build/icon.ico"
    ]
  }
}
