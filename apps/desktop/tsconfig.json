{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vite/client", "node"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": ["../../packages/product-core/renderer/src/*"],
      "@/*": ["../../packages/product-core/renderer/src/*"]
    }
  },
  "include": [
    "src",
    "../../packages/product-core/renderer/src/env.d.ts",
    "../../packages/product-core/renderer/src/**/*",
    "../../packages/product-core/shared/preload-api-types.ts",
    "../../packages/product-core/shared/**/*",
    "../../packages/product-core/types/**/*"
  ],
  "exclude": [
    "../../packages/product-core/**/*.test.ts",
    "../../packages/product-core/**/*.test.tsx",
    "../../packages/product-core/**/__tests__/**",
    "../../packages/product-core/**/*.spec.ts",
    "../../packages/product-core/**/*.spec.tsx"
  ],
  "references": []
}
